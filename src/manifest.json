{
  "manifest_version": 3,
  "name": "Nitpick",
  "version": "0.1.0",
  "description": "UI bug reporting for DevRev",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {},
  "background": {
    "service_worker": "service-worker/index.ts"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://api.devrev.ai/*",
    "https://api.openai.com/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Quote",
        "mac": "Command+Shift+Quote"
      },
      "description": "Activate comment mode"
    }
  }
}
