# Copy to .env and fill in real values
# Get your DevRev PAT from: Settings > Account > Personal Access Tokens

DEVREV_PAT=don:identity:dvrv-us-1:devo/xxx:devu/yyy
CIRCLECI_TOKEN=your-circleci-personal-api-token
CIRCLECI_PROJECT_SLUG=gh/your-org/devrev-web
CIRCLECI_BRANCH=main

# Your snap-in service account ID (for loop guard testing)
# Find this in DevRev: Settings > Snap-ins > Nitpick Bot > Service Account
SERVICE_ACCOUNT_ID=don:identity:dvrv-us-1:devo/xxx:devu/zzz
